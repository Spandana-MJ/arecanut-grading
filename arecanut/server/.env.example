# Copy this to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/arecanut_grading

# JWT Secret - use a long random string
JWT_SECRET=your_long_random_secret_key_here

# Port (Render sets this automatically)
PORT=5000

# ML Service URL
# Local:      http://localhost:5001
# Production: https://your-ml-service.onrender.com
ML_SERVICE_URL=http://localhost:5001

# Your deployed frontend URL (for CORS)
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Python path (local development only)
PYTHON_PATH=C:\Users\spand\AppData\Local\Programs\Python\Python311\python.exe

# Set to 'production' on Render
NODE_ENV=development
